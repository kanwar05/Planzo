{
  "name": "planzo-server",
  "version": "1.0.0",
  "description": "REST API for the Planzo event services marketplace",
  "private": true,
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "check": "node --check server.js && find src -name '*.js' -exec node --check {} \\;",
    "payments:backfill": "node scripts/backfillPaymentFields.js",
    "test": "NODE_ENV=test node --test --test-concurrency=1"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.3",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.9.16",
    "pdfkit": "^0.19.1",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.9",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2"
  }
}
